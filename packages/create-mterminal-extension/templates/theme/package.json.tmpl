{
  "name": "__PACKAGE_NAME__",
  "version": "0.1.0",
  "description": "An mTerminal extension",
  "license": "MIT",
  "type": "module",
  "main": "dist/main.cjs",
  "renderer": "dist/renderer.mjs",
  "engines": {
    "mterminal-api": "^1.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mterminal/extension-api": "^1.0.0"
  },
  "devDependencies": {
    "@mterminal/extension-api": "^1.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "mterminal": {
    "id": "__ID__",
    "displayName": "__DISPLAY_NAME__",
    "activationEvents": ["onCommand:__ID__.greet"],
    "capabilities": ["ui:modal"],
    "contributes": {
      "commands": [
        { "id": "__ID__.greet", "title": "__DISPLAY_NAME__: Greet" }
      ]
    }
  }
}
