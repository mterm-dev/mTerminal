{
  "name": "mterminal",
  "private": true,
  "version": "0.3.1",
  "type": "commonjs",
  "main": "out/main/index.js",
  "description": "Custom terminal emulator with grouped tabs and warm dark UI",
  "author": "arthurr0",
  "license": "MIT",
  "homepage": "https://github.com/arthurr0/mTerminal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arthurr0/mTerminal.git"
  },
  "bugs": {
    "url": "https://github.com/arthurr0/mTerminal/issues"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "package": "electron-vite build && electron-builder --publish never",
    "package:linux": "electron-vite build && electron-builder --linux --publish never",
    "package:win": "electron-vite build && electron-builder --win --publish never",
    "rebuild": "electron-rebuild -f -w node-pty",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@noble/ciphers": "^1.0.0",
    "@noble/hashes": "^1.5.0",
    "@xterm/addon-canvas": "0.8.0-beta.48",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.0.0",
    "pidtree": "^0.6.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "node-pty",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "electron": "latest",
    "electron-builder": "latest",
    "electron-vite": "latest",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
